<Window x:Class="Keylet.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Keylet"
        WindowStyle="None"
        WindowState="Maximized"
        ResizeMode="NoResize"
        Topmost="True"
        Background="#16111F"
        Cursor="None"
        Loaded="OnLoaded"
        Closed="OnClosed">
    <Grid x:Name="RootGrid">
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#20113A" Offset="0" />
                <GradientStop Color="#102A43" Offset="0.45" />
                <GradientStop Color="#123524" Offset="1" />
            </LinearGradientBrush>
        </Grid.Background>

        <Border Margin="44"
                Padding="36"
                CornerRadius="34"
                Background="#D9141020"
                BorderBrush="#66FFFFFF"
                BorderThickness="2">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock x:Name="EmptyHint"
                           Grid.Row="0"
                           Text="Type something magical..."
                           FontFamily="Segoe Print, Comic Sans MS, Segoe UI"
                           FontSize="64"
                           FontWeight="Bold"
                           Foreground="#88FFFFFF"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           TextAlignment="Center" />

                <TextBlock x:Name="TypedText"
                           Grid.Row="0"
                           ClipToBounds="True"
                           FontFamily="Segoe Print, Comic Sans MS, Segoe UI"
                           FontSize="102"
                           FontWeight="Bold"
                           LineHeight="132"
                           LineStackingStrategy="BlockLineHeight"
                           Margin="0,0,0,20"
                           TextAlignment="Left"
                           TextWrapping="Wrap"
                           TextTrimming="None" />

                <TextBlock x:Name="StatusToast"
                           Grid.Row="0"
                           Visibility="Collapsed"
                           Text=""
                           FontFamily="Segoe UI"
                           FontSize="20"
                           FontWeight="SemiBold"
                           Foreground="#FFFDE68A"
                           Background="#AA000000"
                           Padding="14,8"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Top"
                           Margin="0,8,0,0"
                           TextAlignment="Center" />

                <TextBlock Text="Parent exit: Ctrl + Alt + T + 9"
                           Grid.Row="1"
                           HorizontalAlignment="Right"
                           Margin="0,10,8,4"
                           FontFamily="Segoe UI"
                           FontSize="18"
                           Foreground="#77FFFFFF" />
            </Grid>
        </Border>
    </Grid>
</Window>
